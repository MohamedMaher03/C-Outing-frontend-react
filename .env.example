# Environment Variables Template
# Copy this file to .env and .env.local, then fill in your actual values

# API Configuration
VITE_API_BASE_URL=https://dark-olva-tccd-a34be896.koyeb.app


# Google Maps API Key (for venue maps integration)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Application Info
VITE_APP_NAME=HCARS
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_GEOLOCATION=true

# Default Language
VITE_DEFAULT_LANGUAGE=en

# API Timeouts (in milliseconds)
VITE_API_TIMEOUT=30000

# Session Configuration
VITE_SESSION_TIMEOUT=3600000

# Analytics (if using Google Analytics or similar)
VITE_ANALYTICS_ID=your_analytics_id

# Development
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info

# Deployment
VITE_DEPLOYMENT_ENV=development
# Options: development, staging, production
